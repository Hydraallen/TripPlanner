# TripPlanner Configuration
# Copy this file to .env and fill in your values.

# === API Keys ===

# OpenTripMap API key (required for international POI search)
# Get yours at https://opentripmap.io/ (free, 10k req/day)
OPENTRIPMAP_API_KEY=

# Amap API key (required for Chinese destinations)
# Get yours at https://lbs.amap.com/ (free, 5k calls/day)
AMAP_API_KEY=

# === LLM (GLM-5.1) ===
# Used for AI-powered plan generation and chat
# Get yours at https://open.bigmodel.cn/
OPENAI_ENDPOINT=https://open.bigmodel.cn/api/coding/paas/v4
OPENAI_API_KEY=
OPENAI_MODEL_NAME=glm-5.1

# === Database ===
# Default: SQLite (no setup needed)
# Docker: postgresql+asyncpg://tripplanner:tripplanner@postgres:5432/tripplanner
DATABASE_URL=sqlite+aiosqlite:///./trips.db

# === Server ===
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=*
